# ==================================
# DATABASE (local Docker Postgres)
# ==================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omniseller?schema=public"

# ==================================
# REDIS (Docker compose)
# ==================================
REDIS_URL="redis://127.0.0.1:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# ==================================
# SUPABASE STORAGE (optional)
# ==================================
# Leave these blank until you are ready to test storage-backed photo uploads.
STORAGE_BUCKET="omniseller-images"

# ==================================
# NEXTAUTH
# ==================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_WITH_BASE64_32B"

# ==================================
# WEB APP
# ==================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OMNISELLER_API_BASE_URL="http://localhost:3001"

# ==================================
# NEXT PUBLIC SUPABASE STORAGE (optional until Supabase storage is configured)
# ==================================
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE=""

# ==================================
# EBAY OAUTH (fill after creating app in eBay dev portal)
# ==================================
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
EBAY_ENV="PRODUCTION"
EBAY_REDIRECT_URI="http://localhost:3000/api/ebay/callback"

# ==================================
# SHIPPING (optional for local dev)
# ==================================
EASYPOST_API_KEY=""
DEFAULT_SHIP_FROM_NAME="OmniSeller"
DEFAULT_SHIP_FROM_COMPANY="OmniSeller"
DEFAULT_SHIP_FROM_STREET1=""
DEFAULT_SHIP_FROM_STREET2=""
DEFAULT_SHIP_FROM_CITY=""
DEFAULT_SHIP_FROM_STATE=""
DEFAULT_SHIP_FROM_ZIP=""
DEFAULT_SHIP_FROM_COUNTRY="US"
DEFAULT_SHIP_FROM_PHONE=""

# ==================================
# AI LISTING SUGGESTIONS (optional)
# ==================================
OPENAI_MODEL="gpt-4o-mini"

# ==================================
# API
# ==================================
PORT=3001
NODE_ENV=development
EBAY_API_BASE="https://api.ebay.com"
