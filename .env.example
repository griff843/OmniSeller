# ==================================
# DATABASE (local Docker Postgres)
# ==================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omniseller?schema=public"

# ==================================
# REDIS (Docker compose)
# ==================================
REDIS_URL="redis://127.0.0.1:6379"

# ==================================
# SUPABASE STORAGE (optional)
# ==================================
# Leave these blank until you are ready to test storage-backed photo uploads.
STORAGE_BUCKET="omniseller-images"

# ==================================
# NEXTAUTH
# ==================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_WITH_BASE64_32B"

# ==================================
# NEXT PUBLIC (optional until Supabase storage is configured)
# ==================================
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE=""

# ==================================
# EBAY OAUTH (fill after creating app in eBay dev portal)
# ==================================
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
EBAY_ENV="PRODUCTION"
EBAY_REDIRECT_URI="http://localhost:3000/api/ebay/callback"

# ==================================
# SHIPPING (optional for local dev)
# ==================================
SHIPPO_API_KEY=""
# EASYPOST_API_KEY=""

# ==================================
# API
# ==================================
PORT=3001
NODE_ENV=development
